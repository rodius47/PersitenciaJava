    <class>pio.daw.ra8.modelo.Categoria</class>
    <class>pio.daw.ra8.modelo.Producto</class>
    <class>pio.daw.ra8.ejemplos.jpa.Contacto</class>
    <class>pio.daw.ra8.ejemplos.relaciones.Vehiculo</class>
    <class>pio.daw.ra8.ejemplos.relaciones.Coche</class>
    <class>pio.daw.ra8.ejemplos.relaciones.Moto</class>
    <class>pio.daw.ra8.ejemplos.relaciones.Autor</class>
    <class>pio.daw.ra8.ejemplos.relaciones.Libro</class>
        <class>pio.daw.ra8.ejemplos.jpa.Libro</class>
    <class>pio.daw.ra8.mercadoLibre.Simulacion</class>
    <class>pio.daw.ra8.mercadoLibre.Individuo</class>
